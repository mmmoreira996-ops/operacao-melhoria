{
  "name": "operacao-melhoria-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "vector-store:create": "node scripts/create-vector-store.mjs",
    "electron": "electron .",
    "electron:dev": "set VITE_DEV_SERVER_URL=http://localhost:5174&& electron .",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "build": {
    "appId": "br.com.dataia.operacao-melhoria",
    "productName": "DATA IA Operacao",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "vite": "^6.3.5",
    "typescript": "^5.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.468.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12"
  }
}
