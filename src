function Tratativa({ selectedCase }: { selectedCase: NcCase }) {
  const [currentStage, setCurrentStage] = useState(selectedCase.stage)
  const [input, setInput] = useState("")
  const [messages, setMessages] = useState<ChatMessage[]>([
    {
      role: "assistant",
      content: "Ola, estou pronto para ajudar em sua analise. Preciso que voce me de a descricao do problema ou da anomalia que deseja analisar, antes de prosseguirmos.",
    },
  ])
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState("")

  async function sendMessage() {
    const text = input.trim()
    if (!text || loading) return

    const nextMessages: ChatMessage[] = [...messages, { role: "user", content: text }]
    setMessages(nextMessages)
    setInput("")
    setError("")
    setLoading(true)

    try {
      const response = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          caseData: selectedCase,
          stage: currentStage,
          messages: nextMessages,
        }),
      })

      const data = await response.json()
      if (!response.ok) throw new Error(data.error ?? "Falha ao consultar a IA.")
      setMessages((current) => [...current, { role: "assistant", content: data.answer }])
    } catch (err) {
      setError(err instanceof Error ? err.message : "Falha ao consultar a IA.")
    } finally {
      setLoading(false)
    }
  }

  return (
    <section className="treatment-layout">
      <div className="panel">
        <div className="panel-heading">
          <div>
            <h2>{selectedCase.code} - {selectedCase.title}</h2>
          <span>{selectedCase.area} | severidade {selectedCase.severity}</span>
          </div>
          <span className={`badge ${statusClass(selectedCase.status)}`}>{selectedCase.status}</span>
        </div>

        <div className="case-summary">
          <div>
            <span>Problema</span>
            <strong>{selectedCase.problem}</strong>
          </div>
          <div>
            <span>Evidencia inicial</span>
            <strong>{selectedCase.evidence}</strong>
          </div>
        </div>

        <div className="stage-list">
          {analysisMenu.map((stage, index) => (
            <button key={stage} className={currentStage === stage ? "active" : ""} onClick={() => setCurrentStage(stage)}>
              {index + 1}. {stage}
            </button>
          ))}
        </div>

        <div className="form-grid">
          <label>
            Descricao da anomalia
            <textarea defaultValue={selectedCase.problem} />
          </label>
          <label>
            Contencao imediata
            <textarea placeholder="O que foi feito para proteger o cliente/processo?" />
          </label>
          <label>
            Analise de causa
            <textarea placeholder="Causa tecnica, sistemica ou de processo, baseada em evidencia." />
          </label>
          <label>
            Plano e eficacia
            <textarea placeholder="Como saberemos que a acao corretiva funcionou?" />
          </label>
        </div>
      </div>

      <aside className="ai-panel">
        <div className="ai-heading">
          <BrainCircuit size={22} />
          <div>
            <h2>Assistente IA</h2>
            <span>{currentStage}</span>
          </div>
        </div>

        <div className="chat-log">
          {messages.map((message, index) => (
            <div className={`chat-message ${message.role}`} key={`${message.role}-${index}`}>
              {message.content}
            </div>
          ))}
          {loading && (
            <div className="chat-message assistant loading">
              <Loader2 size={16} />
              Analisando...
            </div>
          )}
        </div>

        {error && <div className="feedback warning">{error}</div>}

        <div className="chat-input">
          <textarea value={input} onChange={(event) => setInput(event.target.value)} placeholder="Responda ou peca uma analise da etapa atual..." />
          <button className="primary" onClick={sendMessage} disabled={loading}>
            <MessageSquareText size={16} />
            Enviar
          </button>
        </div>
      </aside>
    </section>
  )
}

function Acoes() {
  return (
    <section className="panel">
      <table>
        <thead>
          <tr>
            <th>Origem</th>
            <th>Acao</th>
            <th>Responsavel</th>
            <th>Prazo</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {actions.map((action) => (
            <tr key={action.id}>
              <td>{action.origin}</td>
              <td>{action.title}</td>
