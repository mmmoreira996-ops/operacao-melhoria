function statusClass(status: string) {
  if (status === "Encerrada" || status === "Concluida" || status === "Finalizado") return "success"
  if (status === "Atrasada" || status === "Critica") return "danger"
  if (status === "Em analise" || status === "Em andamento") return "warning"
  return "neutral"
}

